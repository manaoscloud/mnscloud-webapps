# Public-safe PhoneWeb module configuration.
# Copy to /etc/mnscloud/webapps/apps.d/phoneweb.env.

APP_NAME=phoneweb
APP_REPO_URL=https://github.com/manaoscloud/mnscloud-phoneweb.git
APP_REF=main
APP_BASE_PATH=/phoneweb/
APP_PUBLIC_API_BASE_URL=/api/v1
APP_BUILD_COMMAND="flutter build web --release --base-href ${APP_BASE_PATH}"
