# Public-safe Pulse module configuration.
# Copy to /etc/mnscloud/webapps/apps.d/pulse.env.

APP_NAME=pulse
APP_REPO_URL=https://github.com/manaoscloud/mnscloud-pulse.git
APP_REF=main
APP_BASE_PATH=/pulse/
APP_PUBLIC_API_BASE_URL=/api/v1
APP_BUILD_COMMAND="flutter build web --release --base-href ${APP_BASE_PATH} --dart-define PULSE_PUBLIC_API_BASE_URL=${APP_PUBLIC_API_BASE_URL}"
