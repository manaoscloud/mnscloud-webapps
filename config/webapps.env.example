# MNSCloud WebApps private runtime environment.
# Copy to /etc/mnscloud/webapps/webapps.env and replace placeholders.

WEBAPPS_ROOT=/opt/mnscloud/webapps
WEBAPPS_ENV_DIR=/etc/mnscloud/webapps
WEBAPPS_APPS_DIR=/etc/mnscloud/webapps/apps.d
WEBAPPS_LISTEN_HOST=127.0.0.1
WEBAPPS_LISTEN_PORT=8080
WEBAPPS_USER=mnscloud-webapps
WEBAPPS_GROUP=mnscloud-webapps
WEBAPPS_RUNTIME_KIT_DIR=/opt/mnscloud/runtime-kit
WEBAPPS_RUNTIME_KIT_REPO_URL=https://github.com/manaoscloud/mnscloud-runtime-kit.git
WEBAPPS_RUNTIME_KIT_REF=v0.1.6
WEBAPPS_INSTALL_FLUTTER=true
WEBAPPS_FLUTTER_DIR=/opt/flutter
WEBAPPS_FLUTTER_CHANNEL=stable
WEBAPPS_FLUTTER_BUILD_PROFILE=web
WEBAPPS_FLUTTER_RUN_USER=mnscloud-webapps
WEBAPPS_FLUTTER_HOME=/var/lib/mnscloud-webapps/flutter

# Comma-separated app names to update when --app is not supplied.
WEBAPPS_ENABLED_APPS=phoneweb,pulse
